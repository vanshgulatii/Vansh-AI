# Vansh AI Backend Environment Variables

# OpenAI API Key (required)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Port to run the server on
SERVER_PORT=8000

# Optional: FastAPI docs URL
FASTAPI_DOCS_URL=/docs

# Optional: ChromaDB settings (for future use)
CHROMA_DB_PATH=./chroma_db
CHROMA_DB_HOST=localhost
CHROMA_DB_PORT=8000